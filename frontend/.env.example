# Frontend Environment Variables

# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Authentication
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=baas-portal
VITE_KEYCLOAK_CLIENT_ID=baas-portal-frontend
VITE_KEYCLOAK_CLIENT_SECRET=your-secret-here

# Security
VITE_ENABLE_HTTPS=true
VITE_ENABLE_CSRF_PROTECTION=true
VITE_ENABLE_CORS=true

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# PIX Configuration
VITE_PIX_DICT_API=https://dict-api.central.bcb.gov.br
VITE_PIX_SANDBOXMODE=false

# LGPD
VITE_SHOW_LGPD_BANNER=true
VITE_LGPD_COOKIE_DURATION=2592000

# Logging
VITE_LOG_LEVEL=info
