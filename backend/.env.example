# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/baas_portal
DATABASE_POOL_SIZE=20
DATABASE_SSL=true

# Keycloak / Authentication
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=baas-portal
KEYCLOAK_CLIENT_ID=baas-portal-backend
KEYCLOAK_CLIENT_SECRET=your-secret-here
JWT_SECRET=your-jwt-secret-key-min-32-chars-long
JWT_EXPIRY=24h

# PIX Sandbox
PIX_SANDBOX_MODE=false
PIX_SANDBOX_URL=https://sandbox-pix.central.bcb.gov.br
PIX_CERT_PATH=/certs/pix-cert.pem
PIX_KEY_PATH=/certs/pix-key.pem

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key
ENCRYPTION_IV=your-16-char-iv

# Security
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5173
HELMET_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Audit & Logging
AUDIT_ENABLED=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Email (for LGPD requests)
EMAIL_SERVICE=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# Storage
BACKUP_ENCRYPTION_KEY=your-backup-key
BACKUP_RETENTION_DAYS=365

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
CACHE_TTL=3600

# API Keys
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
